{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"ConnectionStrings": {
		"DefaultConnection": "Host=hostname;Port=5432;Database=inventory_management_system;Username=postgres;"
	},
	"Authentication": {
		"DefaultScheme": "LocalAuthIssuer",
		"Schemes": {
			"Bearer": {
				"ValidAudiences": [
					"https://localhost:7259",
					"http://localhost:5259",
					"http://localhost:5217"
				],
				"ValidIssuer": "http://localhost:5217",
				"ValidAudience": "inventory_management_system_user"
			},
			"LocalAuthIssuer": {
				"ValidAudiences": ["https://localhost:7259", "http://localhost:5259"],
				"ValidIssuer": "local-auth"
			}
		}
	}
}
